# Required OpenRouter provider. Defaults (re-pinned 2026-06-12; the 2.5 family
# was delisted from OpenRouter):
#   cheap/extract/vision = google/gemini-3.1-flash-lite  (fallback: -3.5-flash)
#   reasoning            = google/gemini-3.5-flash        (fallback: -3.1-flash-lite)
OPENROUTER_API_KEY=
GANDER_LLM_PROVIDER=openrouter
OPENROUTER_STRIP_THINK=1
# OPENROUTER_MODEL_REASONING=google/gemini-3.5-flash
# OPENROUTER_MODEL_REASONING_FALLBACK=google/gemini-3.1-flash-lite
# OPENROUTER_MODEL_CHEAP=google/gemini-3.1-flash-lite
# OPENROUTER_MODEL_CHEAP_FALLBACK=google/gemini-3.5-flash
# OPENROUTER_MODEL_EXTRACT=google/gemini-3.1-flash-lite
# OPENROUTER_MODEL_EXTRACT_FALLBACK=google/gemini-3.5-flash
# OPENROUTER_MODEL_VISION=google/gemini-3.1-flash-lite
# OPENROUTER_MODEL_VISION_FALLBACK=google/gemini-3.5-flash
# OPENROUTER_HTTP_REFERER=https://huggingface.co/spaces/fridrichmrtn/probable-goose-machine
# OPENROUTER_APP_TITLE=Gander

# Optional non-paid local provider (Ollama / self-hosted, OpenAI-compatible).
# OFF by default — opt in per slot. Point a slot at your own box with
# GANDER_LLM_PROVIDER_<SLOT>=local; the model comes from the OPENROUTER_MODEL_<SLOT>
# override above or a built-in Ollama default per slot. Vision always uses
# OpenRouter (local models often lack vision), so a vision=local override degrades
# back to OpenRouter. Self-hosted inference is free, so its cost estimates to ~0.
# GANDER_LLM_PROVIDER_CHEAP=local
# GANDER_LLM_PROVIDER_EXTRACT=local
# GANDER_LLM_PROVIDER_REASONING=local
# GANDER_LOCAL_BASE_URL=http://localhost:11434/v1
# GANDER_LOCAL_API_KEY=local

# Ingest defaults:
#   PDF  -> vision transcription through OpenRouter/Gemini
#   DOCX -> deterministic local text extraction
# GANDER_PDF_INGEST_MODE=vision
# GANDER_DOCX_INGEST_MODE=text
# Legacy fallback, still accepted when file-specific modes are unset:
# GANDER_INGEST_MODE=vision

# Optional: comma-separated ddgs salary-search backends.
# Empty/unset defaults to brave,duckduckgo,yahoo,mojeek.
# GANDER_SALARY_SEARCH_BACKENDS=brave,duckduckgo,yahoo,mojeek
