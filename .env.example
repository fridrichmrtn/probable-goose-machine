MINIMAX_API_KEY=
GANDER_MODEL_PROFILE=local

# Optional OpenRouter provider. Defaults:
#   reasoning/extract/cheap/vision = google/gemini-2.5-flash
#   fallback for each slot          = google/gemini-2.5-flash-lite
# With GANDER_LLM_PROVIDER=openrouter, PDF vision and text/JSON stages use OpenRouter.
# MiniMax is only used when GANDER_LLM_PROVIDER=minimax.
# GANDER_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL_REASONING=google/gemini-2.5-flash
# OPENROUTER_MODEL_REASONING_FALLBACK=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_CHEAP=google/gemini-2.5-flash
# OPENROUTER_MODEL_CHEAP_FALLBACK=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_EXTRACT=google/gemini-2.5-flash
# OPENROUTER_MODEL_EXTRACT_FALLBACK=google/gemini-2.5-flash-lite
# OPENROUTER_MODEL_VISION=google/gemini-2.5-flash
# OPENROUTER_MODEL_VISION_FALLBACK=google/gemini-2.5-flash-lite
# OPENROUTER_HTTP_REFERER=https://huggingface.co/spaces/fridrichmrtn/probable-goose-machine
# OPENROUTER_APP_TITLE=Gander
# OPENROUTER_STRIP_THINK=1

# Optional: comma-separated ddgs salary-search backends.
# Empty/unset defaults to brave,duckduckgo,yahoo,mojeek.
# GANDER_SALARY_SEARCH_BACKENDS=brave,duckduckgo,yahoo,mojeek
