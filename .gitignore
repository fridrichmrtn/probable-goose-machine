# Claude Code — infra committed; ignore per-user override + transient state
.claude/settings.local.json
.claude/local/
.claude/.cache/
CLAUDE.local.md

# Codex — local per-user state only; not tracked in git
.codex/

# Per-invocation worktrees
.worktrees/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv / venv
.venv/
venv/

# Env / secrets
.env
.env.*
!.env.example

# Reports (regenerated by scripts/eval_corpus.py)
# Per-CV reports are gitignored; SUMMARY.md is committed because T23 README
# quotes it directly.
reports/*.md
!reports/.gitkeep
!reports/SUMMARY.md

# IDE
.idea/
.vscode/
*.swp
.DS_Store
