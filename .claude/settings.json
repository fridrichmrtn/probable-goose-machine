{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash"
    ]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/auto_approve_readonly_bash.py"
          }
        ]
      }
    ]
  }
}
